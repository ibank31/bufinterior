{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/artikel/layout,_N_T_/artikel/page,_N_T_/artikel"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/artikel/__PAGE__",
    "/artikel",
    "/_index",
    "/_head"
  ]
}